" note: comments are denoted with '"' not '#'
set nocompatible

set number
"set cursorline
set ruler
set showcmd
set showmode
let loaded_matchparen = 1

syntax enable
set background=dark
set laststatus=2
set statusline=%f\ %m%r%h%w\ [FORMAT=%{&ff}]\ [TYPE=%Y]\ %=%l/%L,%v\ %p%%

set formatoptions=r
set autoindent
set ttyfast

set hlsearch
set incsearch
set ignorecase
set smartcase
